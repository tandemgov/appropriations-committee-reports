# GovInfo API (get a free key at https://api.data.gov/signup/)
GOVINFO_API_KEY=DEMO_KEY

# Vision model backend for House PDF extraction
# Options: "gemini" (free, recommended), "openai-compat" (local), "anthropic" (paid)
VISION_BACKEND=gemini

# For Gemini (free — get key at https://aistudio.google.com/apikey):
GEMINI_API_KEY=
VISION_MODEL=gemini-2.0-flash

# For LM Studio (default):
VISION_BASE_URL=http://localhost:1234/v1
VISION_MODEL=qwen2.5-vl
VISION_API_KEY=lm-studio

# For the "nemotron" / "hybrid" backends — a vLLM server hosting
# nvidia/NVIDIA-Nemotron-Parse-v1.2. Point this at whatever host serves it.
NEMOTRON_BASE_URL=http://localhost:8000/v1

# For ollama:
# VISION_BASE_URL=http://localhost:11434/v1
# VISION_MODEL=qwen2.5vl:7b
# VISION_API_KEY=ollama

# For remote GPU server:
# VISION_BASE_URL=http://your-server:8000/v1
# VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# VISION_API_KEY=your-key

# For Anthropic Claude (costs money):
# VISION_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
